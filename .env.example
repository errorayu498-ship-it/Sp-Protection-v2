# ─── Discord Bot Configuration ───────────────────────────────────────────────

# Your Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_bot_token_here

# Your Discord Server (Guild) ID
GUILD_ID=123456789012345678

# The channel ID where members send screenshots
SS_CHANNEL_ID=123456789012345678

# The role ID to give after SS verification
ROLE_ID=123456789012345678

# Your YouTube Channel Link
YOUTUBE_LINK=https://youtube.com/@YourChannel
